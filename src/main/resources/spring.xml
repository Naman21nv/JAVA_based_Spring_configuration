<?xml version="1.0" encoding="UTF-8"?>
<!--
  Spring XML configuration file for demonstration purposes.
  Declares beans and properties that show how to wire dependencies using
  an XML-based configuration. This file coexists with the Java-based
  configuration in this project to illustrate both approaches.
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
      Define an Alien bean with properties injected via XML. The 'com' property
      is set to a new Laptop bean defined inline.
    -->
    <bean id="alien" class="org.example.Alien">
        <property name="age" value="10"/>
        <property name="com">
            <bean class="org.example.Laptop"/>
        </property>
    </bean>

    <!-- A simple Desktop bean definition. Beans without an explicit id will
         receive a generated id based on the class name. -->
    <bean class="org.example.Desktop"/>

</beans>
